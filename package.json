    "./presets/speckit": "./src/presets/speckit.ts",
    "./presets/openspec": "./src/presets/openspec.ts",
    "./work-graph": "./src/workGraph.ts",
    "./mutate": "./src/mutate.ts",
    "./mcp": "./src/mcp.ts",
    "./attest": "./src/attest.ts",
    "./lint": "./src/lint.ts",
