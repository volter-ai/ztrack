{
  "name": "ztrack",
  "version": "0.6.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "ARCHITECTURE.md",
    "CHANGELOG.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "PRESET-GUIDE.md",
    "ROADMAP.md",
    "profiles",
    "scripts/build-node-cli.mjs",
    "scripts/check-ztrack-profile.mjs",
    "scripts/setup-ztrack-repo.mjs",
    "SECURITY.md",
    "SUPPORT.md",
    "backend",
    "boilerplates/README.md",
    "boilerplates/presets",
    "docs",
    "!docs/demo.gif",
    "dist",
    "!dist/src/presets/default.*",
    "!dist/src/presets/spec.*",
    "!dist/src/presets/speckitCore.*",
    "hooks",
    "visualizer",
    "!visualizer/node_modules",
    "!dist/src/**/*.test.*"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./config": {
      "types": "./dist/src/config.d.ts",
      "default": "./dist/src/config.js"
    },
    "./sdk": {
      "types": "./dist/src/sdk.d.ts",
      "default": "./dist/src/sdk.js"
    },
    "./preset-kit": {
      "types": "./dist/src/presetKit.d.ts",
      "default": "./dist/src/presetKit.js"
    },
    "./check": {
      "types": "./dist/src/check.d.ts",
      "default": "./dist/src/check.js"
    },
    "./export": {
      "types": "./dist/src/export.d.ts",
      "default": "./dist/src/export.js"
    },
    "./markdown-model": {
      "types": "./dist/src/markdownModel.d.ts",
      "default": "./dist/src/markdownModel.js"
    },
    "./ac-version": {
      "types": "./dist/src/acVersion.d.ts",
      "default": "./dist/src/acVersion.js"
    },
    "./presets": {
      "types": "./dist/src/presets.d.ts",
      "default": "./dist/src/presets.js"
    },
    "./mutate": {
      "types": "./dist/src/mutate.d.ts",
      "default": "./dist/src/mutate.js"
    },
    "./mcp": {
      "types": "./dist/src/mcp.d.ts",
      "default": "./dist/src/mcp.js"
    },
    "./attest": {
      "types": "./dist/src/attest.d.ts",
      "default": "./dist/src/attest.js"
    },
    "./lint": {
      "types": "./dist/src/lint.d.ts",
      "default": "./dist/src/lint.js"
    },
    "./tx": {
      "types": "./dist/src/tx.d.ts",
      "default": "./dist/src/tx.js"
    },
    "./dsse": {
      "types": "./dist/src/dsse.d.ts",
      "default": "./dist/src/dsse.js"
    },
    "./world-annotations": {
      "types": "./dist/src/worldAnnotations.d.ts",
      "default": "./dist/src/worldAnnotations.js"
    },
    "./world-source-books": {
      "types": "./dist/src/worldSourceBooks.d.ts",
      "default": "./dist/src/worldSourceBooks.js"
    }
  },
  "bin": {
    "ztrack": "dist/cli.js",
    "ztrack-profile-check": "scripts/check-ztrack-profile.mjs",
    "ztrack-setup": "scripts/setup-ztrack-repo.mjs"
  },
  "scripts": {
    "build": "npm run build:node-cli",
    "build:node-cli": "node scripts/build-node-cli.mjs",
    "cli": "bun run src/cli.ts",
    "visualizer": "bun run visualizer/server.ts",
    "prepack": "npm run build:node-cli",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "mdast-util-from-markdown": "2.0.3",
    "mdast-util-gfm": "3.1.0",
    "mdast-util-to-markdown": "2.1.2",
    "micromark-extension-gfm": "3.0.0",
    "zod": "4.4.2"
  },
  "devDependencies": {
    "@types/bun": "^1.2.20",
    "@types/node": "^24.0.0",
    "@volter-ai-dev/twin": "^0.1.0",
    "typescript": "^5.9.0"
  },
  "peerDependencies": {
    "@volter-ai-dev/twin": "*"
  },
  "peerDependenciesMeta": {
    "@volter-ai-dev/twin": {
      "optional": true
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/volter-ai/ztrack.git"
  },
  "homepage": "https://ztrack.dev",
  "bugs": {
    "url": "https://github.com/volter-ai/ztrack/issues"
  },
  "license": "Apache-2.0",
  "keywords": [
    "ai-agents",
    "cli",
    "developer-tools",
    "task-management",
    "issue-tracker",
    "mcp",
    "zod",
    "verification",
    "ci"
  ]
}
