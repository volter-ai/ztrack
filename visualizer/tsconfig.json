{
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "types": ["react", "react-dom"]
  },
  "include": ["client/**/*.ts", "client/**/*.tsx"],
  "exclude": ["client/**/*.test.ts", "client/**/*.test.tsx"]
}
