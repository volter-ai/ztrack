{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "declaration": true,
    "emitDeclarationOnly": false,
    "noEmit": false,
    "outDir": "dist/src",
    "rewriteRelativeImportExtensions": true,
    "rootDir": "src"
  },
  "include": ["src/**/*.ts", "types/**/*.d.ts"],
  "exclude": ["src/**/*.test.ts"]
}
